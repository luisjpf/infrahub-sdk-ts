{
  "name": "infrahub-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Infrahub",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "infrahub-sdk": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./codegen": {
      "import": "./dist/codegen/index.js",
      "types": "./dist/codegen/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "bash tests/e2e/docker-e2e.sh",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "infrahub",
    "sdk",
    "infrastructure",
    "graphql"
  ],
  "author": "OpsMill",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/opsmill/infrahub-sdk-ts.git"
  },
  "bugs": {
    "url": "https://github.com/opsmill/infrahub-sdk-ts/issues"
  },
  "homepage": "https://github.com/opsmill/infrahub-sdk-ts#readme",
  "dependencies": {
    "commander": "^14.0.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
